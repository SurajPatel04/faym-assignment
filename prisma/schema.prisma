// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  USER
  ADMIN
}

enum SaleStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  ADVANCE
  FINAL
  ADJUSTMENT
  REFUND
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REJECTED
}

// ─── MODELS ──────────────────────────────────────────────

model User {
  id                  String   @id @default(cuid())
  username            String   @unique
  email               String   @unique
  passwordHash        String

  role                Role     @default(USER)

  withdrawableBalance Decimal  @default(0) @db.Decimal(10,2)

  lastWithdrawalAt    DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sales               Sale[]
  withdrawals         Withdrawal[]
  payoutTransactions  PayoutTransaction[]
  refreshTokens       RefreshToken[]
}

model Sale {
  id             String     @id @default(cuid())

  userId         String
  user           User       @relation(fields: [userId], references: [id])

  brand          String

  earning        Decimal    @db.Decimal(10,2)

  status         SaleStatus @default(PENDING)

  advancePaid    Boolean    @default(false)
  advanceAmount  Decimal    @default(0) @db.Decimal(10,2)

  reconciledAt   DateTime?

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  payoutTransactions PayoutTransaction[]

  @@index([userId])
  @@index([userId, status])
  @@index([status, advancePaid])
}

model PayoutTransaction {
  id          String            @id @default(cuid())

  userId      String
  user        User              @relation(fields: [userId], references: [id])

  saleId      String?
  sale        Sale?             @relation(fields: [saleId], references: [id])

  type        TransactionType

  amount      Decimal           @db.Decimal(10,2)

  status      TransactionStatus @default(PENDING)

  referenceId String?

  createdAt   DateTime          @default(now())

  @@index([userId])
  @@index([saleId])
  @@unique([saleId, type], name: "unique_advance_final")
}

model Withdrawal {
  id               String           @id @default(cuid())

  userId           String
  user             User             @relation(fields: [userId], references: [id])

  amount           Decimal          @db.Decimal(10,2)

  status           WithdrawalStatus @default(PENDING)

  gatewayReference String?
  gatewayResponse  Json?
  processedAt      DateTime?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([userId])
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)

  @@index([userId])
}
